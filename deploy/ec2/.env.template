# ---- Artsie EC2 Environment Configuration ----
# Copy this file to /opt/artsie/.env and fill in the values.
# This file is read by the systemd service unit on startup.
# Permissions should be restricted: chmod 600 /opt/artsie/.env

# ---- Database (RDS PostgreSQL) ----
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=5432
DB_NAME=artsie
DB_USERNAME=artsie
DB_PASSWORD=changeme

# ---- AWS S3 ----
S3_BUCKET_NAME=your-artsie-media-bucket
AWS_REGION=us-east-1

# ---- Spring ----
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
